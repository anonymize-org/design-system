{
  "name": "@secrecy/design-system",
  "repository": {
    "type": "git",
    "url": "https://github.com/anonymize-org/design-system.git"
  },
  "version": "1.1.0",
  "sideEffects": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "import": "./dist/index.css",
      "require": "./dist/index.css"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "clean": "rm -rf .turbo node_modules dist"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "eslint": "^9.23.0",
    "file-type": "^21.3.3",
    "mammoth": "^1.11.0",
    "postcss": "^8.5.3",
    "tsup": "^8.4.0",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.503.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.7.2",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.1.0",
    "tailwindcss": "^4.1.1",
    "tw-animate-css": "^1.2.5",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
